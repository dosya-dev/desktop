{
  "name": "@dosya-dev/desktop",
  "version": "0.0.1",
  "private": true,
  "description": "dosya.dev desktop client — sync, upload, and manage your files",
  "author": {
    "name": "dosya.dev",
    "email": "hello@dosya.dev"
  },
  "homepage": "https://dosya.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/dosya-dev/desktop"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "cross-env ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder --config electron-builder.yml",
    "package:mac": "electron-vite build && electron-builder --mac --config electron-builder.yml",
    "package:win": "electron-vite build && electron-builder --win --config electron-builder.yml",
    "package:linux": "electron-vite build && electron-builder --linux --config electron-builder.yml",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "electron-vite build && npx playwright test",
    "test:only": "npx playwright test",
    "test:headed": "electron-vite build && npx playwright test --headed",
    "test:ui": "electron-vite build && npx playwright test --ui"
  },
  "dependencies": {
    "@dosya-dev/shared": "file:../../packages/shared",
    "@radix-ui/react-context-menu": "^2.2.6",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tanstack/react-query": "^5.72.2",
    "@tanstack/react-virtual": "^3.13.6",
    "chokidar": "^4.0.3",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.3.9",
    "graceful-fs": "^4.2.11",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.3.8",
    "react-router": "^7.4.0",
    "react-router-dom": "^7.4.0",
    "sonner": "^2.0.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.7.0"
  }
}
